{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "projects-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/projects/{**catch-all}"
        }
      },
      "teams-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/teams/{**catch-all}"
        }
      },
      "tasks-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/tasks/{**catch-all}"
        }
      },
      "boardcolumns-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/boardcolumns/{**catch-all}"
        }
      },
      "subtasks-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/subtasks/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "hubs-route": {
        "ClusterId": "pm-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "documents-route": {
        "ClusterId": "docintel-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/v1/documents/{**catch-all}"
        }
      },
      "chat-route": {
        "ClusterId": "docintel-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/v1/chat/{**catch-all}"
        }
      },
      "webhooks-route": {
        "ClusterId": "docintel-cluster",
        "Match": {
          "Path": "/api/v1/webhooks/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "pm-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "docintel-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  }
}
